program trucoCartas;

uses SysUtils, crt;

const MAX_TARJETAS_GRUPO= 7; //Tarjetas por grupo
      MAX_GRUPOS= 3; //Cantidad de grupos
      MAX_TARJETAS= MAX_TARJETAS_GRUPO*MAX_GRUPOS; //Total de tarjetas.
      MIN_TARJETA_VALOR= 'A'; //Tarjeta incial, en este caso letra A.
      MAX_TARJETA_VALOR= chr(MAX_TARJETAS+ord('A')-1); //Tarjeta final.
type
 tarjetas= MIN_TARJETA_VALOR..MAX_TARJETA_VALOR;
 grupo= array[1..MAX_TARJETAS_GRUPO] of tarjetas;
 mazo= array[1..MAX_TARJETAS] of tarjetas;

 var grupo1, grupo2, grupo3: grupo;
     deck: mazo;
     repetido, error: boolean;
     i,j,numeroGrupo, ronda: byte;
      nUsuario: char;
begin
    error:= false;
    ronda:=0;
    randomize;
    Writeln('Haremos 3 secuencias.. Empecemos..');

    //NUMEROS ALEATORIOS Y LLENADO DEL 'DECK'
    for i:=1 to MAX_TARJETAS do begin
    repeat
    repetido:=false;
    numeroGrupo:= random(ord(MAX_TARJETA_VALOR)-ord(MIN_TARJETA_VALOR)+1)+ord(MIN_TARJETA_VALOR);
    for j := 1 to i - 1 do
    begin
      if deck[j] = chr(numeroGrupo) then
        repetido := true;
    end;
    until repetido= false ;
    deck[i] := chr(numeroGrupo);
    end;
    i:= 1;
    j:= 1;
   repeat
        grupo1[j]:= deck[i];
        i+= 1;
        grupo2[j]:= deck[i];
        i+= 1;
        grupo3[j]:= deck[i];
        i+= 1;
        j+= 1;
    until i >= MAX_TARJETAS;//LLENADO DEL 'DECK' COMPLETO

    //INICIO RONDA
    repeat
    if not error then begin

    writeln('Secuencia ',ronda+1,': ');
    writeln;
    for i:=1 to MAX_TARJETAS_GRUPO do begin
        write('     ');
        for j:=1 to 3 do begin
        write(deck[(i - 1) * 3 + j],'  ');
        end;
        writeln;
    end;//END FOR GRUPOS
    writeln;
    write('En que grupo esta tu tarjeta [1,2,3]: ');
    end;
    readln(nUsuario);
    writeln;
    if nUsuario = '1' then begin
       error:= false;
       for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i]:= grupo3[i];
       end;
       for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i+MAX_TARJETAS_GRUPO]:= grupo1[i];
       end;
       for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i+14]:= grupo2[i];
       end;
    end //END IF = 1
    else if nUsuario = '2' then begin
       error:= false;
        for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i]:= grupo1[i];
       end;
       for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i+MAX_TARJETAS_GRUPO]:= grupo2[i];
       end;
       for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i+14]:= grupo3[i];
       end;
    end//END IF = 2
    else if nUsuario = '3' then begin
       error:= false;
        for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i]:= grupo2[i];
       end;
       for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i+MAX_TARJETAS_GRUPO]:= grupo3[i];
       end;
       for i:=1 to MAX_TARJETAS_GRUPO do begin
           deck[i+14]:= grupo1[i];
       end;
    end //END ULTIMO IF = 3
    else begin
        error:= true;
    end;

    if error then begin
         write('ERROR: Ingresa un numero entre [1,2,3]: ');

    end else begin //VOLVEMOS A BARAJAR SI NO HAY ERROR
        i:= 1;
        j:= 1;
   repeat
        grupo1[j]:= deck[i];
        i+= 1;
        grupo2[j]:= deck[i];
        i+= 1;
        grupo3[j]:= deck[i];
        i+= 1;
        j+= 1;
    until i >= MAX_TARJETAS;
    ronda+=1;//SOLO AUMENTAMOS LAS RONDAS SI NO HAY ERROR
    end;

    until ronda = 3;//FIN DE LAS 3 RONDAS

    write('Buscando en tu mente');
    for i := 1 to 3 do begin
    delay(500); // Requiere la unidad 'crt'
    write('.');
    end;
    writeln;
    writeln;
    write('Obviamente elegiste la ', deck[11]);

    readln;
end.

